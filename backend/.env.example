# wiki-pipeline PoC 자격증명 템플릿. cp .env.example .env 후 값 채움.
# .env 는 절대 커밋하지 않는다 (.gitignore 차단).

# ── LLM 공급자 (중립 설계) ──
LLM_PROVIDER=minimax                       # minimax | anthropic
LLM_BASE_URL=https://api.minimax.io/v1     # M3 OpenAI 호환 엔드포인트
LLM_API_KEY=                               # 공급자 API 키
LLM_MODEL=MiniMax-M3
# M3: 컨텍스트(입력) 1M, 최대 출력 512K. 문서 생성엔 32K면 충분.
LLM_MAX_TOKENS=32768
LLM_TEMPERATURE=0.2

# ── 정적 파이프라인: 사내 GitLab ──
GITLAB_URL=http://wish.mirero.co.kr
GITLAB_TOKEN=                              # project access token
GITLAB_TOKEN_HEADER=PRIVATE-TOKEN          # PRIVATE-TOKEN | Authorization
GITLAB_PROJECT_ID=947
STATIC_FROM_SHA=                           # compare from sha
STATIC_TO_SHA=                             # compare to sha
STATIC_THEMES=intro,requirements,architecture-overview,component-diagram
# 여러 SCM 인스턴스를 함께 돌릴 때 사용. 비우면 위 단일 GITLAB_* 설정을 그대로 사용한다.
# kind: gitlab(사내·gitlab.com — url 필수) | github(github.com — url 생략 가능, project_id는 "owner/repo")
# SCM_SOURCES_JSON=[
#   {"id":"sw-rcs","kind":"gitlab","label":"SW RCS","url":"http://wish.mirero.co.kr","project_id":"947","token":"","token_header":"PRIVATE-TOKEN","themes":"intro,requirements,architecture-overview,component-diagram"},
#   {"id":"pcc30","kind":"gitlab","label":"PCC 3.0","url":"https://gitlab.com","project_id":"group/pcc30","token":""},
#   {"id":"docu-automatic","kind":"github","label":"Docu-Automatic","project_id":"jaeCheon8587/Docu-Automatic","token":""}
# ]

# ── 매뉴얼 파이프라인: 원격제어 MCP ──
MCP_ENDPOINT_URL=http://<host>:9200/sse    # MiVncManagerMcpServer SSE (단일세션은 :9100)
MCP_TRANSPORT=sse                          # sse | streamable_http
MCP_SESSION_HOST=                          # remote 모드 대상 VNC 호스트 IP
MCP_SESSION_PORT=
# OMNIPARSER_URL=                          # (옵션) VLM 화면분석

# ── 매뉴얼 파이프라인: 순회·생성 ──
MANUAL_SCENARIO_FILE=./manual_pipeline/scenarios/sample.json   # poc/ 기준 상대경로
MANUAL_THEMES=user-manual,operator-manual  # 독자 2축 (decision-manual-taxonomy-two-reader)
MANUAL_EXPLORE_STEPS=12                    # 자율 탐색 도구 호출 예산
# 세션 관리 등 부트스트랩은 시나리오 파일의 첫 시나리오로 표현한다 (도구 이름은 서버 실측).
# MANUAL_TOOL_ALLOWLIST=screenshot,screen_info,window,uia,click,type,key_press,scroll,menu,dialog
MANUAL_TOOL_TIMEOUT=90

# ── docs-hub 제출 (PoC=스텁) ──
DOCSHUB_MR_ENABLED=false
DOCSHUB_PROJECT_ID=
DOCSHUB_PROJECT_URL=http://wish.mirero.co.kr/mirero/project/pcc/product-common
DOCSHUB_PROJECT_PATH=mirero/project/pcc/product-common
DOCSHUB_TOKEN=                             # product-common MR 생성/브랜치 push용 토큰
DOCSHUB_TOKEN_HEADER=PRIVATE-TOKEN
DOCSHUB_DEFAULT_BRANCH=master

# ── 관측·출력 ──
OUT_DIR=./out
LOG_LEVEL=INFO

# ── Control Plane (관리 서버 — decision-control-plane-fastapi) ──
CONTROL_HOST=127.0.0.1
CONTROL_PORT=8420
# 기본값은 PostgreSQL (docker-compose 의 'db' 서비스). 직접 기동 시 빈 값이면
# postgresql+psycopg://wpipe:wpipe@db:5432/wpipe 로 시도 — 컨테이너 외부라면
# CONTROL_DB_URL 을 명시하거나 로컬 postgres 를 띄워야 한다.
# 개발/테스트 용 SQLite 가 필요하면 명시적으로 override:
# CONTROL_DB_URL=sqlite:///./out/control-plane.sqlite
# 자체 토큰 인증 (decision-server-vm-self-token): "이름:토큰" 쉼표 구분. 비우면 개발 모드(무인증)
CONTROL_API_TOKENS=
# Data Plane 러너 webhook 전용 토큰
CONTROL_RUNNER_TOKEN=
# 시크릿 at-rest 암호화 키 (Fernet). 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONTROL_SECRET_KEY=

# ── 알림 (decision-email-alerting) ──
NOTIFY_MODE=log                            # log | smtp
ADMIN_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=wiki-pipeline@localhost

# ── 스케줄·보존 ──
DEFAULT_SCHEDULE_CRON=0 20 * * 1-5         # 야간 배치 평일 20:00 (decision-nightly-batch)
SCHEDULER_ENABLED=true
EVENT_RETENTION_DAYS=30                    # 완료 run 상세 이벤트 보존 일수 (0=무제한)

# ── 재시도·동시성·한도 (운영 튜닝 노브) ──
SCM_RETRY_ATTEMPTS=3
LLM_RETRY_ATTEMPTS=4
WRITER_MAX_RETRY=2
STATIC_REDUCE_CONCURRENCY=4
STATIC_MAP_CONCURRENCY=6
STATIC_READ_MAX_CHARS=40000
