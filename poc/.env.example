# wiki-pipeline PoC 자격증명 템플릿. cp .env.example .env 후 값 채움.
# .env 는 절대 커밋하지 않는다 (.gitignore 차단).

# ── LLM 공급자 (중립 설계) ──
LLM_PROVIDER=minimax                       # minimax | anthropic
LLM_BASE_URL=https://api.minimax.io/v1     # M3 OpenAI 호환 엔드포인트
LLM_API_KEY=                               # 공급자 API 키
LLM_MODEL=MiniMax-M3
# M3: 컨텍스트(입력) 1M, 최대 출력 512K. 문서 생성엔 32K면 충분.
LLM_MAX_TOKENS=32768
LLM_TEMPERATURE=0.2

# ── 정적 파이프라인: 사내 GitLab ──
GITLAB_URL=http://wish.mirero.co.kr
GITLAB_TOKEN=                              # project access token
GITLAB_TOKEN_HEADER=PRIVATE-TOKEN          # PRIVATE-TOKEN | Authorization
GITLAB_PROJECT_ID=947
STATIC_FROM_SHA=                           # compare from sha
STATIC_TO_SHA=                             # compare to sha
STATIC_THEMES=intro,requirements,architecture-overview,component-diagram

# ── 매뉴얼 파이프라인: 원격제어 MCP ──
MCP_ENDPOINT_URL=http://<host>:9200/sse    # MiVncManagerMcpServer SSE (단일세션은 :9100)
MCP_TRANSPORT=sse                          # sse | streamable_http
MCP_SESSION_HOST=                          # remote 모드 대상 VNC 호스트 IP
MCP_SESSION_PORT=
# OMNIPARSER_URL=                          # (옵션) VLM 화면분석

# ── 매뉴얼 파이프라인: 순회·생성 ──
MANUAL_SCENARIO_FILE=./manual_pipeline/scenarios/sample.json   # poc/ 기준 상대경로
MANUAL_THEMES=user-manual,operator-manual  # 독자 2축 (decision-manual-taxonomy-two-reader)
MANUAL_EXPLORE_STEPS=12                    # 자율 탐색 도구 호출 예산
# 세션 관리 등 부트스트랩은 시나리오 파일의 첫 시나리오로 표현한다 (도구 이름은 서버 실측).
# MANUAL_TOOL_ALLOWLIST=screenshot,screen_info,window,uia,click,type,key_press,scroll,menu,dialog
MANUAL_TOOL_TIMEOUT=90

# ── docs-hub 제출 (PoC=스텁) ──
DOCSHUB_MR_ENABLED=false
DOCSHUB_PROJECT_ID=

# ── 관측·출력 ──
OUT_DIR=./out
LOG_LEVEL=INFO
