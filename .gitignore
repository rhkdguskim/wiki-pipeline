.omc/
.DS_Store

# Obsidian 개인 UI 상태 (세션마다 바뀜 — 공유 대상 아님)
# 루트 및 하위 vault(wiki/ 등) 모두 적용
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json

# Obsidian 그래프 뷰 상태 (zoom/scale 등 개인 UI)
**/.obsidian/graph.json

# ── 운영 코드 (backend/ · frontend/) ────────────────────────
# 자격증명 — 절대 커밋 금지 (LLM API 키·GitLab/GitHub 토큰·MCP endpoint)
.env
**/.env
!**/.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# Frontend dependencies / build
node_modules/
frontend/dist/

# 실행 산출물 (생성 문서·관측 로그·스크린샷·체크포인트·이벤트)
out/
backend/out/
backend/output/
backend/logs/
backend/**/*.jsonl
backend/**/*.sqlite
